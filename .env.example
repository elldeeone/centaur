# Sandbox
SANDBOX_IMAGE=tempo-ai-sandbox:latest
GITHUB_REPOS=tempoxyz/tempo,tempoxyz/ai,tempoxyz/tempo-apps,tempoxyz/tempo-web,tempoxyz/ai-payments
