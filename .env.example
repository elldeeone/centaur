# =============================================================================
# Tempo AI v2 — Central Secrets File
# =============================================================================
# All plugin secrets can be defined here. Plugins inherit from this file.
# Per-plugin .env files can override specific values.
# Environment variables (Docker/k8s/sops/1pw) take final precedence.
# =============================================================================

# --- Core ---
DATABASE_URL=postgresql://tempo:tempo_dev@localhost:5432/ai_v2
OPENAI_API_KEY=
API_SECRET_KEY=
UI_PASSWORD=
SLACK_SIGNING_SECRET=

# --- CI-injected secrets ---
# These are injected by GitHub Actions into docker-compose env vars.
# The secret manager is isolated to the firewall; API/auth/slackbot
# get bootstrap secrets from CI env vars, not from the secret manager.
# Required CI secrets:
#   OP_SERVICE_ACCOUNT_TOKEN  — 1Password SDK token for secrets service
#   SECRET_MANAGER_TOKEN      — auth token for secrets HTTP sidecar
#   API_SECRET_KEY            — root API key (api + auth)
#   SLACK_SIGNING_SECRET      — Slack webhook HMAC verification (api)
#   UI_PASSWORD               — UI login password (auth)
#   OPENAI_API_KEY            — deploy notification script
#   SLACK_BOT_TOKEN           — deploy notification script

# --- Extractors (ETL pipeline) ---
POV_SLACK_TOKEN=
POV_SLACK_USER_TOKEN=
POV_LINEAR_API_KEY=
POV_GITHUB_TOKEN=
POV_GOOGLE_CLIENT_ID=
POV_GOOGLE_CLIENT_SECRET=
POV_GOOGLE_REFRESH_TOKEN=
POV_GOOGLE_SERVICE_ACCOUNT_KEY=
POV_GRANOLA_ACCESS_TOKEN=
POV_GRANOLA_ACCESS_TOKEN_2=
POV_GRANOLA_ENTERPRISE_API_KEY=
POV_ATTIO_API_KEY=
POV_PYLON_API_TOKEN=
POV_BETTERSTACK_API_TOKEN=

# --- Plugin Secrets ---

# Websearch / Deep Research
EXA_API_KEY=
ANTHROPIC_API_KEY=
DEEP_RESEARCH_MODEL=claude-opus-4-6

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Linear
LINEAR_API_KEY=

# GSuite (Google Calendar, Drive, Gmail)
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# Allium (on-chain analytics)
ALLIUM_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

